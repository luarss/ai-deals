<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Model Deal Tracker — Best Value LLMs Today</title>
  <meta name="description" content="Daily ranking of the best-value AI models by intelligence per dollar, coding performance, and speed. Powered by Artificial Analysis data." />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            brand: { 500: '#6366f1', 600: '#4f46e5', 700: '#4338ca' }
          }
        }
      }
    }
  </script>
  <style>
    /* Smooth sort-indicator transitions */
    th.sortable { user-select: none; }
    th.sortable::after { content: ' ⇅'; opacity: 0.3; font-size: 0.7em; }
    th.sort-asc::after  { content: ' ▲'; opacity: 1; }
    th.sort-desc::after { content: ' ▼'; opacity: 1; }

    /* Size filter chips */
    .tier-chip { cursor: pointer; transition: all 0.15s ease; }
    .tier-chip.active { background-color: #4f46e5; border-color: #6366f1; color: #fff; }
    .tier-chip:not(.active):hover { border-color: #6366f1; color: #a5b4fc; }

    /* Hidden rows (filtered out) */
    tr.tier-hidden { display: none; }

    /* Hero gradient animation */
    @keyframes gradientShift {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .hero-gradient {
      background: linear-gradient(135deg, #1e1b4b, #312e81, #1e3a5f, #0f172a);
      background-size: 300% 300%;
      animation: gradientShift 8s ease infinite;
    }

    /* Table row hover */
    tbody tr:hover td { background-color: rgba(99,102,241,0.07); }

    /* Pulse badge */
    .live-badge::before {
      content: '';
      display: inline-block;
      width: 6px; height: 6px;
      background: #22c55e;
      border-radius: 50%;
      margin-right: 6px;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }

    /* Sticky table header */
    thead th { position: sticky; top: 0; z-index: 10; }
  </style>
</head>
<body class="dark bg-gray-950 text-gray-100 min-h-screen font-sans antialiased">

  <!-- ===== HEADER ===== -->
  <header class="border-b border-gray-800 px-4 py-5">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold tracking-tight">
          <span class="text-indigo-400">AI</span> Deal Tracker
        </h1>
        <p class="text-sm text-gray-400 mt-0.5">Intelligence per dollar · updated daily</p>
      </div>
      <div class="flex flex-wrap items-center gap-3 text-xs">
        <span class="live-badge text-green-400 font-medium">Live</span>
        <span class="bg-gray-800 px-3 py-1 rounded-full text-gray-300">
          {{ total_models }} models tracked
        </span>
        <span class="bg-gray-800 px-3 py-1 rounded-full text-gray-400">
          {{ last_updated }}
        </span>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 py-10 space-y-12">

    <!-- ===== HERO BEST DEAL ===== -->
    {% if hero_model %}
    <section>
      <p class="text-xs uppercase tracking-widest text-indigo-400 mb-3 font-semibold">🏆 Best Deal Today</p>
      <div class="hero-gradient rounded-2xl p-8 border border-indigo-800/60 shadow-2xl">
        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
          <div>
            <h2 class="text-3xl sm:text-4xl font-bold text-white">{{ hero_model.name }}</h2>
            {% if hero_model.creator %}
            <p class="text-indigo-300 mt-1 text-sm">{{ hero_model.creator }}</p>
            {% endif %}
            {% if hero_model.composite_deal_score is not none %}
            <div class="mt-3 inline-flex items-center gap-2 bg-indigo-600/30 border border-indigo-500/40 rounded-full px-4 py-1.5">
              <span class="text-xs text-indigo-300 uppercase tracking-wide">Deal Score</span>
              <span class="text-xl font-mono font-bold text-white">{{ "%.2f"|format(hero_model.composite_deal_score) }}</span>
            </div>
            {% endif %}
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-2">
            <div class="bg-white/5 rounded-xl p-4 text-center">
              <p class="text-xs text-gray-400 mb-1">Intelligence</p>
              <p class="text-2xl font-mono font-bold">
                {{ hero_model.intelligence_score | fmt_score(1) }}
                <span class="text-sm text-gray-400 font-normal">/60</span>
              </p>
            </div>
            <div class="bg-white/5 rounded-xl p-4 text-center">
              <p class="text-xs text-gray-400 mb-1">Blended Price</p>
              <p class="text-2xl font-mono font-bold">{{ hero_model.price_blended | fmt_price }}</p>
              <p class="text-xs text-gray-500">/1M tokens</p>
            </div>
            <div class="bg-white/5 rounded-xl p-4 text-center">
              <p class="text-xs text-gray-400 mb-1">Value Score</p>
              <p class="text-2xl font-mono font-bold">{{ hero_model.value_score | fmt_score(1) }}</p>
              <p class="text-xs text-gray-500">intel / $</p>
            </div>
            <div class="bg-white/5 rounded-xl p-4 text-center">
              <p class="text-xs text-gray-400 mb-1">Speed</p>
              <p class="text-2xl font-mono font-bold">{{ hero_model.output_speed_tps | fmt_speed }}</p>
              <p class="text-xs text-gray-500">tokens/sec</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    {% endif %}

    <!-- ===== RUNNER-UP CARDS ===== -->
    {% if runner_up_cards %}
    <section>
      <p class="text-xs uppercase tracking-widest text-gray-500 mb-4 font-semibold">Runners-Up</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {% for model in runner_up_cards %}
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-indigo-700/50 transition-colors">
          <div class="flex items-start justify-between gap-2 mb-4">
            <div>
              <p class="text-xs text-gray-500 mb-0.5">#{{ loop.index + 1 }}</p>
              <h3 class="font-semibold text-base leading-snug">{{ model.name }}</h3>
            </div>
            {% if model.composite_deal_score is not none %}
            <span class="shrink-0 bg-indigo-900/50 text-indigo-300 text-xs font-mono px-2 py-1 rounded-lg">
              {{ "%.2f"|format(model.composite_deal_score) }}
            </span>
            {% endif %}
          </div>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between text-gray-400">
              <span>Intelligence</span>
              <span class="font-mono text-gray-200">{{ model.intelligence_score | fmt_score(1) }}/60</span>
            </div>
            <div class="flex justify-between text-gray-400">
              <span>Blended price</span>
              <span class="font-mono text-gray-200">{{ model.price_blended | fmt_price }}/1M</span>
            </div>
            <div class="flex justify-between text-gray-400">
              <span>Value score</span>
              <span class="font-mono text-gray-200">{{ model.value_score | fmt_score(1) }}</span>
            </div>
            <div class="flex justify-between text-gray-400">
              <span>Coding index</span>
              <span class="font-mono text-gray-200">{{ model.coding_index | fmt_score(1) }}</span>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <!-- ===== AI INSIGHTS ===== -->
    {% if insights %}
    <section class="bg-gray-900 border border-gray-800 rounded-xl p-7">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-lg">🤖</span>
        <h2 class="text-base font-semibold">AI Analysis</h2>
        <span class="text-xs bg-indigo-900/60 text-indigo-300 px-2 py-0.5 rounded-full ml-1">DeepSeek</span>
      </div>
      <div class="text-gray-300 leading-relaxed text-sm space-y-4">
        {% for para in insights.split('\n\n') %}
        {% if para.strip() %}
        <p>{{ para.strip() }}</p>
        {% endif %}
        {% endfor %}
      </div>
      <p class="mt-5 text-xs text-gray-600">Generated {{ generated_at }} · Data: artificialanalysis.ai</p>
    </section>
    {% endif %}

    <!-- ===== FULL MODEL TABLE ===== -->
    <section>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
        <h2 class="text-base font-semibold">All Models</h2>
        <div class="flex flex-wrap items-center gap-2">
          <!-- Size filter chips -->
          <span class="text-xs text-gray-500 mr-1">Filter by size:</span>
          <button class="tier-chip active text-xs px-3 py-1 rounded-full border border-gray-700 text-gray-300"
                  data-tier="all" onclick="setTierFilter(this)">
            All <span class="tier-count ml-1 opacity-60"></span>
          </button>
          <button class="tier-chip text-xs px-3 py-1 rounded-full border border-gray-700 text-gray-400"
                  data-tier="frontier" onclick="setTierFilter(this)"
                  title="Proprietary / closed-source models (GPT, Claude, Gemini…)">
            Frontier <span class="tier-count ml-1 opacity-60"></span>
          </button>
          <button class="tier-chip text-xs px-3 py-1 rounded-full border border-gray-700 text-gray-400"
                  data-tier="large" onclick="setTierFilter(this)"
                  title="Open-weight models ≥70B parameters">
            Large 70B+ <span class="tier-count ml-1 opacity-60"></span>
          </button>
          <button class="tier-chip text-xs px-3 py-1 rounded-full border border-gray-700 text-gray-400"
                  data-tier="medium" onclick="setTierFilter(this)"
                  title="Open-weight models 15–70B parameters">
            Medium 15-70B <span class="tier-count ml-1 opacity-60"></span>
          </button>
          <button class="tier-chip text-xs px-3 py-1 rounded-full border border-gray-700 text-gray-400"
                  data-tier="small" onclick="setTierFilter(this)"
                  title="Open-weight models 3–15B parameters">
            Small 3-15B <span class="tier-count ml-1 opacity-60"></span>
          </button>
          <button class="tier-chip text-xs px-3 py-1 rounded-full border border-gray-700 text-gray-400"
                  data-tier="nano" onclick="setTierFilter(this)"
                  title="Open-weight models &lt;3B parameters">
            Nano &lt;3B <span class="tier-count ml-1 opacity-60"></span>
          </button>
        </div>
      </div>
      <p class="text-xs text-gray-600 mb-2">Click column headers to sort · <span id="visible-count"></span></p>

      <!-- Mobile scroll hint -->
      <p class="text-xs text-gray-600 mb-2 sm:hidden">← scroll →</p>

      <div class="overflow-x-auto rounded-xl border border-gray-800">
        <table id="model-table" class="w-full text-sm border-collapse">
          <thead class="bg-gray-900 text-gray-400 text-xs uppercase">
            <tr>
              <th class="sortable px-4 py-3 text-left whitespace-nowrap cursor-pointer" data-col="name" data-type="string">Model</th>
              <th class="sortable px-4 py-3 text-right whitespace-nowrap cursor-pointer" data-col="intel" data-type="number">Intelligence</th>
              <th class="sortable px-4 py-3 text-right whitespace-nowrap cursor-pointer" data-col="price" data-type="number">Price /1M</th>
              <th class="sortable px-4 py-3 text-right whitespace-nowrap cursor-pointer" data-col="value" data-type="number">Value Score</th>
              <th class="sortable px-4 py-3 text-right whitespace-nowrap cursor-pointer" data-col="coding" data-type="number">Coding</th>
              <th class="sortable px-4 py-3 text-right whitespace-nowrap cursor-pointer" data-col="speed" data-type="number">Speed t/s</th>
              <th class="sortable px-4 py-3 text-right whitespace-nowrap cursor-pointer" data-col="ctx" data-type="number">Context</th>
              <th class="sortable px-4 py-3 text-right whitespace-nowrap cursor-pointer" data-col="deal" data-type="number">Deal Score ↓</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800/60">
            {% for model in all_models %}
            <tr class="transition-colors"
                data-name="{{ model.name }}"
                data-intel="{{ model.intelligence_score if model.intelligence_score is not none else '' }}"
                data-price="{{ model.price_blended if model.price_blended is not none else '' }}"
                data-value="{{ model.value_score if model.value_score is not none else '' }}"
                data-coding="{{ model.coding_index if model.coding_index is not none else '' }}"
                data-speed="{{ model.output_speed_tps if model.output_speed_tps is not none else '' }}"
                data-ctx="{{ model.context_window_k if model.context_window_k is not none else '' }}"
                data-deal="{{ model.composite_deal_score if model.composite_deal_score is not none else '' }}"
                data-tier="{{ model.size_tier }}">
              <td class="px-4 py-3 font-medium text-gray-100 whitespace-nowrap">
                {% if loop.index <= 3 %}
                <span class="text-indigo-400 mr-1.5 text-xs">#{{ loop.index }}</span>
                {% endif %}
                {{ model.name }}
                {% if model.creator %}
                <span class="text-gray-500 text-xs ml-1">· {{ model.creator }}</span>
                {% endif %}
              </td>
              <td class="px-4 py-3 text-right font-mono text-gray-300">{{ model.intelligence_score | fmt_score(1) }}</td>
              <td class="px-4 py-3 text-right font-mono text-gray-300">{{ model.price_blended | fmt_price }}</td>
              <td class="px-4 py-3 text-right font-mono
                {% if model.value_score is not none and model.value_score > 100 %}text-green-400
                {% elif model.value_score is not none and model.value_score > 30 %}text-yellow-400
                {% else %}text-gray-300{% endif %}">
                {{ model.value_score | fmt_score(1) }}
              </td>
              <td class="px-4 py-3 text-right font-mono text-gray-300">{{ model.coding_index | fmt_score(1) }}</td>
              <td class="px-4 py-3 text-right font-mono text-gray-300">{{ model.output_speed_tps | fmt_speed }}</td>
              <td class="px-4 py-3 text-right font-mono text-gray-300">{{ model.context_window_k | fmt_context }}</td>
              <td class="px-4 py-3 text-right font-mono font-semibold
                {% if model.composite_deal_score is not none and model.composite_deal_score > 0.7 %}text-indigo-300
                {% elif model.composite_deal_score is not none and model.composite_deal_score > 0.4 %}text-gray-200
                {% else %}text-gray-400{% endif %}">
                {% if model.composite_deal_score is not none %}
                {{ "%.2f"|format(model.composite_deal_score) }}
                {% else %}—{% endif %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ===== METHODOLOGY NOTE ===== -->
    <section class="bg-gray-900/50 border border-gray-800/50 rounded-xl p-6 text-xs text-gray-500 space-y-2">
      <h3 class="text-gray-400 font-medium mb-2">Methodology</h3>
      <p><strong class="text-gray-300">Value Score</strong> = Intelligence Index / Blended Price. Higher = more intelligence per dollar.</p>
      <p><strong class="text-gray-300">Coding Value</strong> = Coding Index / Blended Price.</p>
      <p><strong class="text-gray-300">Deal Score</strong> = weighted normalised composite: 50% value score + 30% coding value + 20% output speed.</p>
      <p><strong class="text-gray-300">Blended Price</strong> uses Artificial Analysis's 7:2:1 cache/input/output ratio where available; falls back to 2:1 input/output.</p>
      <p>Data sourced from <a href="https://artificialanalysis.ai/leaderboards/models" class="text-indigo-400 hover:underline" target="_blank" rel="noopener">artificialanalysis.ai</a>. Analysis by <a href="https://deepseek.com" class="text-indigo-400 hover:underline" target="_blank" rel="noopener">DeepSeek</a>. Updated {{ generated_at }}.</p>
    </section>

  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="border-t border-gray-800 mt-10 px-4 py-6 text-center text-xs text-gray-600">
    <p>
      Data: <a href="https://artificialanalysis.ai" class="hover:text-gray-400 transition-colors">artificialanalysis.ai</a>
      · Analysis: <a href="https://deepseek.com" class="hover:text-gray-400 transition-colors">DeepSeek AI</a>
      · <a href="https://github.com" class="hover:text-gray-400 transition-colors">View source</a>
    </p>
    <p class="mt-1">Not affiliated with Artificial Analysis. Rankings are computed independently.</p>
  </footer>

  <!-- ===== CLIENT-SIDE SORT + TIER FILTER ===== -->
  <script>
    (function () {
      const table  = document.getElementById('model-table');
      const tbody  = table.querySelector('tbody');
      let currentCol = 'deal';
      let ascending  = false;
      let activeTier = 'all';

      // ── Helpers ──────────────────────────────────────────────────────────
      function allRows() { return Array.from(tbody.querySelectorAll('tr')); }

      function visibleRows() {
        return allRows().filter(r => !r.classList.contains('tier-hidden'));
      }

      // ── Tier filter ───────────────────────────────────────────────────────
      function applyTierFilter() {
        allRows().forEach(row => {
          const tier = row.dataset.tier || 'frontier';
          const hide = activeTier !== 'all' && tier !== activeTier;
          row.classList.toggle('tier-hidden', hide);
        });
        updateVisibleCount();
        updateRankBadges(visibleRows());
      }

      function updateVisibleCount() {
        const n   = visibleRows().length;
        const tot = allRows().length;
        const el  = document.getElementById('visible-count');
        if (el) el.textContent = activeTier === 'all'
          ? `${tot} models`
          : `${n} of ${tot} models`;
      }

      // Populate per-chip counts once on load
      function populateCounts() {
        const counts = {};
        allRows().forEach(r => {
          const t = r.dataset.tier || 'frontier';
          counts[t] = (counts[t] || 0) + 1;
        });
        counts['all'] = allRows().length;
        document.querySelectorAll('.tier-chip').forEach(chip => {
          const t  = chip.dataset.tier;
          const el = chip.querySelector('.tier-count');
          if (el && counts[t] !== undefined) el.textContent = counts[t];
        });
      }

      window.setTierFilter = function(btn) {
        activeTier = btn.dataset.tier;
        document.querySelectorAll('.tier-chip').forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        applyTierFilter();
      };

      // ── Sort ──────────────────────────────────────────────────────────────
      function compare(a, b, col, type, asc) {
        const va = a.dataset[col] || '';
        const vb = b.dataset[col] || '';
        if (va === '' && vb === '') return 0;
        if (va === '') return 1;
        if (vb === '') return -1;
        const result = type === 'number'
          ? parseFloat(va) - parseFloat(vb)
          : va.localeCompare(vb, undefined, { sensitivity: 'base' });
        return asc ? result : -result;
      }

      function updateRankBadges(rows) {
        // Remove all existing badges first
        tbody.querySelectorAll('span.rank-badge').forEach(b => b.remove());
        // Re-add for top 3 visible rows
        rows.slice(0, 3).forEach((row, idx) => {
          const nameCell = row.querySelector('td:first-child');
          if (!nameCell) return;
          const badge = document.createElement('span');
          badge.className = 'rank-badge text-indigo-400 mr-1.5 text-xs';
          badge.textContent = `#${idx + 1}`;
          nameCell.prepend(badge);
        });
      }

      function sortTable(col, type) {
        if (col === currentCol) {
          ascending = !ascending;
        } else {
          currentCol = col;
          ascending = type === 'string';
        }

        const rows = allRows();
        rows.sort((a, b) => compare(a, b, col, type, ascending));
        rows.forEach(row => tbody.appendChild(row));

        updateRankBadges(visibleRows());

        table.querySelectorAll('th.sortable').forEach(th =>
          th.classList.remove('sort-asc', 'sort-desc'));
        const activeHeader = table.querySelector(`th[data-col="${col}"]`);
        if (activeHeader)
          activeHeader.classList.add(ascending ? 'sort-asc' : 'sort-desc');
      }

      table.querySelectorAll('th.sortable').forEach(th => {
        th.addEventListener('click', () =>
          sortTable(th.dataset.col, th.dataset.type || 'string'));
      });

      // ── Init ─────────────────────────────────────────────────────────────
      const defaultHeader = table.querySelector('th[data-col="deal"]');
      if (defaultHeader) defaultHeader.classList.add('sort-desc');
      populateCounts();
      updateVisibleCount();
      updateRankBadges(visibleRows());
    })();
  </script>

</body>
</html>
